# --- Harbor environment ---
# Copy to .env.local for local development. Never commit real secrets.

# OpenRouter (server-side only — never exposed to the browser).
# When empty, Harbor runs in demo mode automatically.
OPENROUTER_API_KEY=

# Optional last-resort fallback on a DIFFERENT provider (separate rate-limit pool). Used only when
# every free OpenRouter model fails. Mistral's free "Experiment" tier is $0 (no card; rate-limited).
# Keep your Mistral account on the free tier to stay at $0. Get a key: https://console.mistral.ai/
MISTRAL_API_KEY=

# Private beta access gate.
BETA_ACCESS_CODE=harbor-beta
# Use a long random string in production (>= 32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETA_SESSION_SECRET=dev-only-insecure-secret-change-me-please-32chars
BETA_GATE_ENABLED=true

# Soft per-browser daily task budget (free-model friendly).
FREE_DAILY_TASK_BUDGET=15

# Public app config.
NEXT_PUBLIC_APP_NAME=Harbor
# Force demo mode even when a key is set (used by tests). "true" / "false".
NEXT_PUBLIC_DEMO_MODE=false

# Limits.
MAX_FILE_SIZE_MB=10
MAX_ATTACHMENTS_PER_TASK=6
MAX_URL_PAGES=12

# Web search for research-capable services (Research, Verify, Challenge, Brief, Meeting, etc.).
# "auto" (default) tries, in order: SearXNG (if SEARXNG_URL set) -> Brave (if key) -> Wikipedia.
# Other values: "none", "wikipedia", "brave", "searxng", "duckduckgo".
SEARCH_PROVIDER=auto

# === Unlimited, $0, full-web search (recommended) ===
# Point this at a SearXNG instance you control. SearXNG is open-source metasearch with NO
# query cap and no per-query cost. Self-host in one command (free forever):
#   docker run -d --name searxng -p 8080:8080 \
#     -e "SEARXNG_SETTINGS__SEARCH__FORMATS=[html,json]" searxng/searxng
# then set SEARXNG_URL to its public URL. (Public instances block servers; use your own.)
SEARXNG_URL=

# Optional: a free Brave Search API key (full web, but the free tier is capped ~2000/month).
# Get one at https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# Owner-only model-call diagnostics at /diagnostics. Leave empty to disable entirely.
DIAGNOSTICS_TOKEN=
